# ─── Supabase ───────────────────────────────────────────────────────────────
# Find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only. Has full DB access. NEVER expose to the browser.
# Settings → API → Service role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── Anthropic ──────────────────────────────────────────────────────────────
# https://console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── PDF worker (Fly.io) ────────────────────────────────────────────────────
# Public URL of your deployed pdf-worker app
PDF_WORKER_URL=https://masa-cv-pdf.fly.dev

# Shared bearer secret. Set the SAME value as a Fly.io secret on the worker.
# Generate with: openssl rand -hex 32
RENDER_SHARED_SECRET=replace-me-with-a-long-random-string
